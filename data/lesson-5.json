  "grammar": [
    {
      "id": "G5.1",
      "pattern": "N에 vs N에서",
      "description": "에 indicates a static location (existence) or a destination. 에서 indicates the location where an activity takes place.",
      "examples": [
        { "kor": "집에 계세요.", "eng": "He is at home. (Static)" },
        { "kor": "공원에서 운동해요.", "eng": "I exercise at the park. (Dynamic Activity)" }
      ]
    },
    {
      "id": "G5.2",
      "pattern": "Subject + Object + Verb (SOV)",
      "description": "The basic word order is Subject-Object-Verb. The order of subject and object is flexible, but the verb must always come at the end.",
      "examples": [
        { "kor": "유미가 교실에서 한국어를 공부해요.", "eng": "Yumi studies Korean in the classroom." },
        { "kor": "교실에서 한국어를 유미가 공부해요.", "eng": "Yumi studies Korean in the classroom (emphasis changed)." }
      ]
    },
    {
      "id": "G5.3",
      "pattern": "Vst + (으)러 + 가다/오다",
      "description": "Indicates the purpose of going or coming. Parallel to '(in order) to [verb]'.",
      "examples": [
